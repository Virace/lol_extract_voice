#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "${ROOT_DIR}"

if command -v python3 >/dev/null 2>&1; then
  python3 scripts/check_version_suffix.py
elif command -v python >/dev/null 2>&1; then
  python scripts/check_version_suffix.py
else
  echo "[fail] 未找到 python3/python，无法执行版本后缀校验。"
  exit 1
fi
