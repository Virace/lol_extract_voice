# LoL音频解包工具环境变量示例
# 将此文件复制为.lol.env文件并填写合适的值

# 游戏根目录（必填）
LOL_GAME_PATH="D:/Games/Tencent/WeGameApps/英雄联盟"

# 游戏区域代码
LOL_GAME_REGION="zh_CN"  # 可选：zh_CN, en_US, ja_JP, ko_KR, fr_FR等

# 输出目录（必填）
LOL_OUTPUT_PATH="D:/LoLAudio"

# 排除的音频类型 (默认值: "SFX,MUSIC")
# 如果想解包所有类型，可以设置为空值: LOL_EXCLUDE_TYPE=""
LOL_EXCLUDE_TYPE="SFX,MUSIC"  # 音频类型：VO(语音), SFX(音效), MUSIC(音乐)

# 是否按类型对输出目录进行分组 (默认值: False)
# False (默认): audios/Champions/英雄/皮肤/类型/...
# True: audios/类型/Champions/英雄/皮肤/...
LOL_GROUP_BY_TYPE=False

# https://github.com/bnnm/wwiser/releases
LOL_WWISER_PATH=""

# --- Remote 模式（可选） ---
# 启用 remote 模式时，默认会自动解析最新 live 快照
LOL_SOURCE_MODE="local_path"  # 可选：local_path, remote_snapshot
LOL_REMOTE_LIVE_REGION="EUW"  # 可选：Riot live 区服，默认 EUW

# 如果你需要固定某个快照、复现问题或调试指定 manifest，可同时填写以下三项
LOL_REMOTE_VERSION=""
LOL_REMOTE_LCU_MANIFEST_URL=""
LOL_REMOTE_GAME_MANIFEST_URL=""
